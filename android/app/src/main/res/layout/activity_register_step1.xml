<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7F7F8">

    <!-- 상단 네비게이션 바 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="#FEFEFE"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@null"
            android:contentDescription="뒤로가기" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="회원가입"
            android:textSize="18sp"
            android:textColor="#1A1C1E"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- 오른쪽 여백용 빈 뷰 (버튼과 균형) -->
        <View
            android:layout_width="32dp"
            android:layout_height="32dp" />

    </LinearLayout>

    <!-- 본문 영역 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="20dp">

        <!-- 진행바 + 1/2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <!-- 진행바 배경 -->
            <FrameLayout
                android:layout_width="200dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_progress_track">

                <!-- 진행바 채움 (50%) -->
                <View
                    android:layout_width="100dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_progress_fill" />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1/2"
                android:textSize="14sp"
                android:textColor="#414752"
                android:textStyle="bold"
                android:layout_marginLeft="12dp" />

        </LinearLayout>

        <!-- 제목 + 설명 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="서비스 이용 동의"
                android:textSize="17sp"
                android:textColor="#1A1C1E"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="On-Safe 서비스 이용을 위해 아래 약관에 동의해주세요."
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- 전체 동의 -->
        <LinearLayout
            android:id="@+id/layoutAgreeAll"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_card_white"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <!-- 원형 체크박스 -->
            <View
                android:id="@+id/checkAll"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_check_circle_unchecked" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="전체 동의"
                android:textSize="14sp"
                android:textColor="#1A1C1E"
                android:textStyle="bold"
                android:layout_marginLeft="12dp" />

        </LinearLayout>

        <!-- 개별 약관 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_white"
            android:layout_marginBottom="12dp">

            <!-- 이용약관 동의 (필수) -->
            <LinearLayout
                android:id="@+id/layoutAgree1"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:paddingLeft="20dp"
                android:paddingRight="16dp"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/check1"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/bg_check_square_unchecked" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="12dp"
                    android:text="이용약관 동의"
                    android:textSize="11sp"
                    android:textColor="#1A1C1E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(필수)"
                    android:textSize="11sp"
                    android:textColor="#4D80FF"
                    android:layout_marginRight="8dp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    android:contentDescription="약관 보기" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#F3F4F6" />

            <!-- 개인정보 수집 및 이용 동의 (필수) -->
            <LinearLayout
                android:id="@+id/layoutAgree2"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:paddingLeft="20dp"
                android:paddingRight="16dp"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/check2"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/bg_check_square_unchecked" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="12dp"
                    android:text="개인정보 수집 및 이용 동의"
                    android:textSize="11sp"
                    android:textColor="#1A1C1E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(필수)"
                    android:textSize="11sp"
                    android:textColor="#4D80FF"
                    android:layout_marginRight="8dp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    android:contentDescription="약관 보기" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#F3F4F6" />

            <!-- 민감정보 처리 동의 (필수) -->
            <LinearLayout
                android:id="@+id/layoutAgree3"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:paddingLeft="20dp"
                android:paddingRight="16dp"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/check3"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/bg_check_square_unchecked" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="12dp"
                    android:text="민감정보(건강·위치 데이터) 처리 동의"
                    android:textSize="11sp"
                    android:textColor="#1A1C1E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(필수)"
                    android:textSize="11sp"
                    android:textColor="#4D80FF"
                    android:layout_marginRight="8dp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    android:contentDescription="약관 보기" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#F3F4F6" />

            <!-- 마케팅 정보 수신 동의 (선택) -->
            <LinearLayout
                android:id="@+id/layoutAgree4"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:paddingLeft="20dp"
                android:paddingRight="16dp"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/check4"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/bg_check_square_unchecked" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="12dp"
                    android:text="마케팅 정보 수신 동의"
                    android:textSize="11sp"
                    android:textColor="#1A1C1E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(선택)"
                    android:textSize="11sp"
                    android:textColor="#9FA6AC"
                    android:layout_marginRight="8dp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    android:contentDescription="약관 보기" />

            </LinearLayout>

        </LinearLayout>

        <!-- 여백 채우기 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 다음 버튼 (비활성 상태) -->
        <Button
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="다음"
            android:textColor="#FEFEFE"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_blue"
            android:alpha="0.4"
            android:enabled="false" />

    </LinearLayout>

</LinearLayout>