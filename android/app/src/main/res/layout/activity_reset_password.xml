<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7F7F8">

    <!-- 상단 네비게이션 바 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="#FEFEFE"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@null"
            android:contentDescription="뒤로가기" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="비밀번호 변경"
            android:textSize="18sp"
            android:textColor="#1A1C1E"
            android:textStyle="bold"
            android:gravity="center" />

        <View
            android:layout_width="32dp"
            android:layout_height="32dp" />

    </LinearLayout>

    <!-- 본문 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="20dp">

        <!-- 입력 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_white"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- 현재 비밀번호 (설정에서 진입 시에만 표시) -->
            <LinearLayout
                android:id="@+id/layoutCurrentPw"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="현재 비밀번호"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="8dp">

                    <EditText
                        android:id="@+id/etCurrentPw"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="현재 비밀번호를 입력하세요"
                        android:textColor="#1A1C1E"
                        android:textSize="14sp"
                        android:paddingLeft="16dp"
                        android:paddingRight="48dp"
                        android:background="@drawable/bg_input_rounded"
                        android:inputType="textPassword"
                        android:singleLine="true" />

                    <ImageButton
                        android:id="@+id/btnToggleCurrentPw"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginRight="12dp"
                        android:src="@drawable/ic_eye"
                        android:background="@null"
                        android:contentDescription="현재 비밀번호 보기" />

                </FrameLayout>

            </LinearLayout>

            <!-- 새 비밀번호 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="비밀번호"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="50dp">

                <EditText
                    android:id="@+id/etNewPw"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="영문, 숫자, 특수문자 포함 8자 이상"
                    android:textColor="#1A1C1E"
                    android:textSize="14sp"
                    android:paddingLeft="16dp"
                    android:paddingRight="48dp"
                    android:background="@drawable/bg_input_rounded"
                    android:inputType="textPassword"
                    android:singleLine="true" />

                <ImageButton
                    android:id="@+id/btnToggleNewPw"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginRight="12dp"
                    android:src="@drawable/ic_eye"
                    android:background="@null"
                    android:contentDescription="새 비밀번호 보기" />

            </FrameLayout>

            <TextView
                android:id="@+id/tvNewPwMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <!-- 비밀번호 확인 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="비밀번호 확인"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="6dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="50dp">

                <EditText
                    android:id="@+id/etNewPwConfirm"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="비밀번호를 다시 입력하세요"
                    android:textColor="#1A1C1E"
                    android:textSize="14sp"
                    android:paddingLeft="16dp"
                    android:paddingRight="48dp"
                    android:background="@drawable/bg_input_rounded"
                    android:inputType="textPassword"
                    android:singleLine="true" />

                <ImageButton
                    android:id="@+id/btnToggleNewPwConfirm"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginRight="12dp"
                    android:src="@drawable/ic_eye"
                    android:background="@null"
                    android:contentDescription="비밀번호 확인 보기" />

            </FrameLayout>

            <TextView
                android:id="@+id/tvNewPwConfirmMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:layout_marginTop="4dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- 여백 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 저장하기 버튼 -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="저장하기"
            android:textColor="#FEFEFE"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_blue"
            android:alpha="0.4"
            android:enabled="false" />

    </LinearLayout>

</LinearLayout>