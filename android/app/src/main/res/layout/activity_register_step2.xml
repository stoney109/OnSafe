<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7F7F8">

    <!-- 상단 네비게이션 바 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="#FEFEFE"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@null"
            android:contentDescription="뒤로가기" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="회원가입"
            android:textSize="18sp"
            android:textColor="#1A1C1E"
            android:textStyle="bold"
            android:gravity="center" />

        <View
            android:layout_width="32dp"
            android:layout_height="32dp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="20dp">

            <!-- 진행바 + 2/2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <FrameLayout
                    android:layout_width="200dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_progress_track">
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_progress_fill" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2/2"
                    android:textSize="14sp"
                    android:textColor="#414752"
                    android:textStyle="bold"
                    android:layout_marginLeft="12dp" />

            </LinearLayout>

            <!-- 제목 + 설명 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="개인정보 입력"
                android:textSize="17sp"
                android:textColor="#1A1C1E"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="정확한 정보를 입력해주세요."
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp" />

            <!-- 입력 카드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:layout_marginBottom="12dp">

                <!-- 아이디 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="아이디"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etId"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="영문/숫자 6~12자"
                        android:textColor="#1A1C1E"
                        android:textSize="14sp"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:background="@drawable/bg_input_rounded"
                        android:inputType="text"
                        android:singleLine="true" />

                    <Button
                        android:id="@+id/btnCheckId"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="중복 확인"
                        android:textSize="14sp"
                        android:textColor="#FEFEFE"
                        android:textStyle="bold"
                        android:background="@drawable/bg_button_blue"
                        android:layout_marginLeft="8dp"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvIdMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone" />

                <!-- 비밀번호 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="비밀번호"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="6dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp">

                    <EditText
                        android:id="@+id/etPw"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="영문, 숫자, 특수문자 포함 8자 이상"
                        android:textColor="#1A1C1E"
                        android:textSize="14sp"
                        android:paddingLeft="16dp"
                        android:paddingRight="48dp"
                        android:background="@drawable/bg_input_rounded"
                        android:inputType="textPassword"
                        android:singleLine="true" />

                    <ImageButton
                        android:id="@+id/btnTogglePw"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginRight="12dp"
                        android:src="@drawable/ic_eye"
                        android:background="@null"
                        android:contentDescription="비밀번호 보기" />

                </FrameLayout>

                <TextView
                    android:id="@+id/tvPwMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone" />

                <!-- 비밀번호 확인 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="비밀번호 확인"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="6dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp">

                    <EditText
                        android:id="@+id/etPwConfirm"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="비밀번호를 다시 입력하세요"
                        android:textColor="#1A1C1E"
                        android:textSize="14sp"
                        android:paddingLeft="16dp"
                        android:paddingRight="48dp"
                        android:background="@drawable/bg_input_rounded"
                        android:inputType="textPassword"
                        android:singleLine="true" />

                    <ImageButton
                        android:id="@+id/btnTogglePwConfirm"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginRight="12dp"
                        android:src="@drawable/ic_eye"
                        android:background="@null"
                        android:contentDescription="비밀번호 확인 보기" />

                </FrameLayout>

                <TextView
                    android:id="@+id/tvPwConfirmMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone" />

                <!-- 보호자 이름 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="보호자 이름"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="이름을 입력하세요"
                    android:textColor="#1A1C1E"
                    android:textSize="14sp"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:background="@drawable/bg_input_rounded"
                    android:inputType="textPersonName"
                    android:singleLine="true" />

                <!-- 전화번호 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="전화번호"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="010-0000-0000"
                    android:textColor="#1A1C1E"
                    android:textSize="14sp"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:background="@drawable/bg_input_rounded"
                    android:inputType="phone"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/tvPhoneMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone" />

                <!-- 이메일 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="이메일"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="example@email.com"
                        android:textColor="#1A1C1E"
                        android:textSize="14sp"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:background="@drawable/bg_input_rounded"
                        android:inputType="textEmailAddress"
                        android:singleLine="true" />

                    <Button
                        android:id="@+id/btnVerifyEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="인증 요청"
                        android:textSize="14sp"
                        android:textColor="#FEFEFE"
                        android:textStyle="bold"
                        android:background="@drawable/bg_button_blue"
                        android:layout_marginLeft="8dp"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvEmailMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />

                <!-- 이메일 인증코드 -->
                <LinearLayout
                    android:id="@+id/layoutEmailCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1">

                            <EditText
                                android:id="@+id/etEmailCode"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:hint="인증코드 6자리"
                                android:textColor="#1A1C1E"
                                android:textSize="14sp"
                                android:paddingLeft="16dp"
                                android:paddingRight="72dp"
                                android:background="@drawable/bg_input_rounded"
                                android:inputType="number"
                                android:singleLine="true" />

                            <TextView
                                android:id="@+id/tvEmailTimer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical|end"
                                android:layout_marginEnd="12dp"
                                android:text="3:00"
                                android:textSize="13sp"
                                android:textColor="#EF4444" />

                        </FrameLayout>

                        <Button
                            android:id="@+id/btnConfirmCode"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="확인"
                            android:textSize="14sp"
                            android:textColor="#FEFEFE"
                            android:textStyle="bold"
                            android:background="@drawable/bg_button_blue"
                            android:layout_marginLeft="8dp"
                            android:paddingLeft="16dp"
                            android:paddingRight="16dp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvEmailResend"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="인증코드를 다시 받기"
                        android:textSize="12sp"
                        android:textColor="#4D80FF"
                        android:layout_marginTop="6dp"
                        android:layout_marginStart="8dp"
                        android:visibility="visible" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvEmailVerified"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓ 이메일 인증이 완료되었습니다."
                    android:textSize="11sp"
                    android:textColor="#22C55E"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone" />

                <!-- 주소 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="주소"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etAddress"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="도로명 주소를 검색하세요"
                    android:textColor="#1A1C1E"
                    android:textSize="14sp"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:background="@drawable/bg_input_rounded"
                    android:focusable="false"
                    android:clickable="true"
                    android:singleLine="true"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/etAddressDetail"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="상세 주소 (동, 호수 등)"
                    android:textColor="#1A1C1E"
                    android:textSize="14sp"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:background="@drawable/bg_input_rounded"
                    android:singleLine="true" />

            </LinearLayout>

            <!-- 안내 박스 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_info_box"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:gravity="top"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginRight="8dp"
                    android:src="@drawable/ic_info"
                    android:contentDescription="안내" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="입력하신 정보는 긴급 상황 시 연락처로 사용됩니다.\n정확한 정보를 입력해주세요."
                    android:textSize="11sp"
                    android:textColor="#4D80FF"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

            <!-- 가입 완료 버튼 -->
            <Button
                android:id="@+id/btnComplete"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="가입 완료"
                android:textColor="#FEFEFE"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_blue"
                android:alpha="0.4"
                android:enabled="false" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>