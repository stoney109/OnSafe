<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7F7F8">

    <!-- 상단 네비게이션 바 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="#FEFEFE"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@null"
            android:contentDescription="뒤로가기" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="아이디 찾기"
            android:textSize="18sp"
            android:textColor="#1A1C1E"
            android:textStyle="bold"
            android:gravity="center" />

        <View
            android:layout_width="32dp"
            android:layout_height="32dp" />

    </LinearLayout>

    <!-- 본문 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="20dp">

        <!-- 입력 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_white"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- 설명 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="가입 시 등록한 이름과 이메일로 아이디를 확인할 수 있습니다."
                android:textSize="13sp"
                android:textColor="#6B7280"
                android:layout_marginBottom="24dp" />

            <!-- 이름 라벨 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="이름"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <!-- 이름 입력 -->
            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="홍길동"
                android:textColor="#1A1C1E"
                android:textSize="14sp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:background="@drawable/bg_input_rounded"
                android:inputType="textPersonName"
                android:singleLine="true"
                android:layout_marginBottom="16dp" />

            <!-- 이메일 라벨 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="이메일 주소"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <!-- 이메일 입력 + 인증요청 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="example@email.com"
                    android:textColor="#1A1C1E"
                    android:textSize="14sp"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:background="@drawable/bg_input_rounded"
                    android:inputType="textEmailAddress"
                    android:singleLine="true" />

                <Button
                    android:id="@+id/btnRequestCode"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="인증 요청"
                    android:textSize="14sp"
                    android:textColor="#FEFEFE"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_blue"
                    android:layout_marginLeft="8dp"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp" />

            </LinearLayout>

            <!-- 인증코드 입력칸 + 타이머 (인증요청 후 표시) -->
            <LinearLayout
                android:id="@+id/layoutCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal">

                    <!-- 인증코드 입력 + 타이머 오버레이 -->
                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">

                        <EditText
                            android:id="@+id/etCode"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="인증코드 6자리"
                            android:textColor="#1A1C1E"
                            android:textSize="14sp"
                            android:paddingLeft="16dp"
                            android:paddingRight="72dp"
                            android:background="@drawable/bg_input_rounded"
                            android:inputType="number"
                            android:singleLine="true" />

                        <!-- 타이머 텍스트 (입력칸 오른쪽 내부) -->
                        <TextView
                            android:id="@+id/tvTimer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical|end"
                            android:layout_marginEnd="12dp"
                            android:text="3:00"
                            android:textSize="13sp"
                            android:textColor="#EF4444" />

                    </FrameLayout>

                    <Button
                        android:id="@+id/btnConfirm"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="확인"
                        android:textSize="14sp"
                        android:textColor="#FEFEFE"
                        android:textStyle="bold"
                        android:background="@drawable/bg_button_blue"
                        android:layout_marginLeft="8dp"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp" />

                </LinearLayout>

                <!-- 재전송 버튼 (만료 시 표시) -->
                <TextView
                    android:id="@+id/tvResend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="인증코드를 다시 받기"
                    android:textSize="12sp"
                    android:textColor="#4D80FF"
                    android:layout_marginTop="6dp"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

        <!-- 아이디 결과 카드 (인증 완료 후 표시) -->
        <LinearLayout
            android:id="@+id/layoutResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_white"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="찾은 아이디"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvFoundId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="18sp"
                android:textColor="#1A1C1E"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- 여백 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 로그인으로 돌아가기 -->
        <Button
            android:id="@+id/btnGoLogin"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="로그인으로 돌아가기"
            android:textColor="#FEFEFE"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_blue" />

    </LinearLayout>

</LinearLayout>