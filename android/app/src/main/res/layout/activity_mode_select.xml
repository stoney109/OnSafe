<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#F7F7F8"
    android:paddingLeft="16dp"
    android:paddingRight="16dp"
    android:paddingTop="52dp"
    android:paddingBottom="20dp">

    <!-- 본문 영역 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- 제목 + 설명 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="사용 모드 선택"
                android:textSize="24sp"
                android:textColor="#1A1C1E"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="이 기기의 역할을 선택해주세요."
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="설정에서 언제든지 변경할 수 있습니다."
                android:textSize="12sp"
                android:textColor="#6B7280" />

        </LinearLayout>

        <!-- 카드 목록 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 보호자 모드 카드 -->
            <LinearLayout
                android:id="@+id/cardGuardian"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_mode_card_selected"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="24dp"
                android:layout_marginBottom="16dp">

                <!-- 보호자 아이콘 -->
                <FrameLayout
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_mode_icon_blue">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_person"
                        android:contentDescription="보호자 아이콘" />

                </FrameLayout>

                <!-- 보호자 텍스트 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="보호자 모드"
                        android:textSize="16sp"
                        android:textColor="#1A1C1E"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="어르신의 낙상을 실시간으로 모니터링하고 긴급 알림을 받습니다."
                        android:textSize="13sp"
                        android:textColor="#6B7280"
                        android:lineSpacingExtra="3dp" />

                    <!-- 태그 영역 -->
                    <com.google.android.flexbox.FlexboxLayout
                        xmlns:app="http://schemas.android.com/apk/res-auto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:flexWrap="wrap"
                        app:alignItems="flex_start">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="실시간 영상 확인"
                            android:textSize="11sp"
                            android:textColor="#4D80FF"
                            android:textStyle="bold"
                            android:background="@drawable/bg_tag_blue"
                            android:paddingLeft="10dp"
                            android:paddingRight="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:layout_marginRight="8dp"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="위험 알림 수신"
                            android:textSize="11sp"
                            android:textColor="#4D80FF"
                            android:textStyle="bold"
                            android:background="@drawable/bg_tag_blue"
                            android:paddingLeft="10dp"
                            android:paddingRight="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:layout_marginRight="8dp"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="사고 이력 조회"
                            android:textSize="11sp"
                            android:textColor="#4D80FF"
                            android:textStyle="bold"
                            android:background="@drawable/bg_tag_blue"
                            android:paddingLeft="10dp"
                            android:paddingRight="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp" />

                    </com.google.android.flexbox.FlexboxLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- 카메라 모드 카드 -->
            <LinearLayout
                android:id="@+id/cardCamera"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_mode_card_normal"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="24dp">

                <!-- 카메라 아이콘 -->
                <FrameLayout
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_mode_icon_gray">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_camera"
                        android:contentDescription="카메라 아이콘" />

                </FrameLayout>

                <!-- 카메라 텍스트 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="카메라 모드"
                        android:textSize="16sp"
                        android:textColor="#1A1C1E"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="이 기기를 고정 카메라로 사용하여 영상을 보호자에게 전송합니다."
                        android:textSize="13sp"
                        android:textColor="#6B7280"
                        android:lineSpacingExtra="3dp" />

                    <!-- 태그 영역 -->
                    <com.google.android.flexbox.FlexboxLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:flexWrap="wrap"
                        app:alignItems="flex_start">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="영상 촬영·전송"
                            android:textSize="11sp"
                            android:textColor="#6B7280"
                            android:background="@drawable/bg_tag_gray"
                            android:paddingLeft="10dp"
                            android:paddingRight="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:layout_marginRight="8dp"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="상시 모니터링"
                            android:textSize="11sp"
                            android:textColor="#6B7280"
                            android:background="@drawable/bg_tag_gray"
                            android:paddingLeft="10dp"
                            android:paddingRight="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp" />

                    </com.google.android.flexbox.FlexboxLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- 다음 버튼 -->
    <Button
        android:id="@+id/btnNext"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="다음"
        android:textColor="#FEFEFE"
        android:textSize="18sp"
        android:textStyle="bold"
        android:background="@drawable/bg_button_blue"
        android:alpha="0.4"
        android:enabled="false" />

</LinearLayout>